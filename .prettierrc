{
  "$schema": "https://json.schemastore.org/prettierrc",
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "bracketSpacing": true,
  "trailingComma": "es5",
  "quoteProps": "consistent",
  "arrowParens": "avoid",
  "embeddedLanguageFormatting": "auto"
}
