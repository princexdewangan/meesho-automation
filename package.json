{
  "name": "meesho-automation-root",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24",
    "bun": ">=1.3"
  },
  "workspaces": [
    "apps/dashboard",
    "apps/worker",
    "packages/shared"
  ],
  "scripts": {
    "dev:dashboard": "npm run dev --workspace=apps/dashboard",
    "dev:worker": "npm run dev --workspace=apps/worker",
    "build:dashboard": "npm run build --workspace=apps/dashboard",
    "build:worker": "npm run build --workspace=apps/worker",
    "start:dashboard": "npm start --workspace=apps/dashboard",
    "start:worker": "npm start --workspace=apps/worker",
    "lint:dashboard": "npm run lint --workspace=apps/dashboard",
    "db:generate": "npm run db:generate --workspace=apps/dashboard",
    "db:push": "npm run db:push --workspace=apps/dashboard",
    "db:migrate": "npm run db:migrate --workspace=apps/dashboard",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace=apps/dashboard",
    "db:studio": "npm run db:studio --workspace=apps/dashboard",
    "format": "prettier --write \"**/*.{ts,tsx,md,js,jsx,cjs,mjs,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,js,jsx,cjs,mjs,json,yml,yaml}\""
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "prettier": "^3.2.5"
  }
}
